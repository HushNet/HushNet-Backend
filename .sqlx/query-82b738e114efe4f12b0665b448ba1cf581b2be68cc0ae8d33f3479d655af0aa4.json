{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, target_node_id, logical_msg_id, payload,\n               attempt_count, last_attempt, next_attempt, status, created_at\n        FROM federation_outbox\n        WHERE status = 'pending'\n          AND next_attempt <= NOW()\n        ORDER BY next_attempt ASC\n        LIMIT 100\n        ",
